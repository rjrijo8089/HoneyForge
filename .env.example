# ─────────────────────────────────────────────────────────────────────────────
# HoneyForge — Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored; this file is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── Demo / Clean mode ────────────────────────────────────────────────────────
# true  → all pages load with simulated honeypot telemetry (default for dev)
# false → all pages show empty states; only records you create are shown
NEXT_PUBLIC_ENABLE_DEMO_MODE=true

# ── Supabase ─────────────────────────────────────────────────────────────────
# Find these in your Supabase project Settings › API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Server-side only — never expose to the browser.
# Used by API routes and server actions for privileged database access.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── AI Services (server-side only) ───────────────────────────────────────────
# These keys are consumed exclusively in server-side code (API routes /
# Server Actions). They must NEVER appear in client bundles.
# See SECURITY.md for the enforcement rules.

# Anthropic — default AI provider for the Intelligence Summary engine
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — optional alternative provider
OPENAI_API_KEY=sk-...

# Azure OpenAI — optional; set endpoint in the AI Configuration panel
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/

# Ollama — local model inference; no key required
# OLLAMA_BASE_URL=http://localhost:11434

# ── Threat Intelligence Feed API Keys (server-side only) ─────────────────────
# Used by the IOC Enrichment service to query external reputation databases.
# Leave blank to run the service in mock/stub mode.
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=
GREYNOISE_API_KEY=

# ── Application ───────────────────────────────────────────────────────────────
# Base URL used for absolute links in email notifications and reports.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Alerting Integrations (server-side only) ─────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
PAGERDUTY_INTEGRATION_KEY=
